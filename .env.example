# Copy to server/.env for local development. Never commit real values.
# In production these are set in the Render dashboard (Environment).

# MongoDB Atlas connection string (mongodb+srv://...). Rotate any leaked credential first.
MONGO_URI=

# Strong random secret for signing JWTs.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Allowed browser origin for CORS in dev (the Vite dev server).
# In production the app is same-origin, so this can be left blank.
CLIENT_ORIGIN=http://localhost:5173

# production | development
NODE_ENV=development

# Email (password reset). Optional in dev: if RESEND_API_KEY is unset, the reset
# link is logged to the server console instead of being emailed.
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev
