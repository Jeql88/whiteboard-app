{
  "name": "whiteboard-app",
  "private": true,
  "version": "1.0.0",
  "description": "Real-time collaborative whiteboard (Excalidraw + Socket.IO + MongoDB). Backend on Railway, frontend on Vercel.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@clerk/react": "^6.7.2"
  },
  "scripts": {
    "build": "npm run build --workspace client",
    "start": "node server/index.js",
    "dev:server": "node --env-file=server/.env server/index.js",
    "dev:client": "npm run dev --workspace client"
  }
}
